# 数据库（本地开发用 127.0.0.1，Docker 中会被 docker-compose 覆写为 postgres）
DATABASE_URL=postgresql+asyncpg://wikiio:wikiio%40lck@127.0.0.1:5432/wikiio_db

# Redis（本地开发用 127.0.0.1，Docker 中会被 docker-compose 覆写为 redis）
REDIS_URL=redis://127.0.0.1:6379/0

# JWT密钥（用于登录token，随机字符串，生产环境请务必更换）
SECRET_KEY=wikiio-secret-key-change-this-in-production-2024

# 邮件配置（暂时留空，后面再填）
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=

# 环境（Docker 中会被 docker-compose 覆写为 production）
ENVIRONMENT=development